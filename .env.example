# Real client identifiers for running against a real document set.
# Copy to `.env` (git-ignored) and fill in. The committed defaults in
# src/shipment_review/config.py are synthetic; these override them at runtime.

SAR_BRAND=YourBrand
SAR_CONTRACT_PREFIX=ABCD
SAR_PRODUCT_KEYWORDS=YourBrand,接收终端
SAR_COMMENT_MARKER=YourBrand产品实际出货内容
# single-character OCR look-alike folds, "FROM:TO" comma-separated
SAR_OCR_NAME_CONFUSIONS=
